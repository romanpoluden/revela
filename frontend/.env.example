# No secrets are required for the current frontend-only educational mock.
#
# Future production inference should use the Revela Hugging Face backend API
# client and expose only non-secret browser-safe Vite variables here, for example:
# VITE_REVELA_INFERENCE_BACKEND_URL="https://example-hf-space.hf.space"
#
# Optional future flag, not wired yet:
# VITE_REVELA_ENABLE_LIVE_INFERENCE="true"
